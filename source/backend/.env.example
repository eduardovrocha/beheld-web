# Exemplo das variaveis de ambiente do backend Rails (beheld-backend).
#
# Em producao, este conteudo vai pra `/etc/beheld/app.env` no VPS (perms 600).
# O docker-compose de producao carrega esse arquivo via `env_file:` — ver
# web/deploy/production/docker-compose.yml.
#
# Em desenvolvimento, copie pra `web/source/backend/.env` (gitignored) ou
# exporte as variaveis no shell. Defaults para dev (Mailpit local) estao
# embutidos nas configs — sem precisar de SMTP real.
#
# Credenciais de DB ficam em `/etc/beheld/postgres.env` (arquivo separado);
# nao incluir aqui pra reduzir o blast radius de um vazamento.

# ─── URLs publicas ─────────────────────────────────────────────────────────
# Host raiz do portal (SPA). Usado pelo CompanyMailer para montar o magic
# link e por qualquer URL absoluta gerada nos mailers. Sem barra no fim.
PORTAL_PUBLIC_URL=https://beheld.dev

# Host + protocolo usados pelos url helpers do Rails (`*_url`) nos mailers.
# Devem casar com PORTAL_PUBLIC_URL.
MAILER_DEFAULT_HOST=beheld.dev
MAILER_DEFAULT_PROTOCOL=https

# ─── Mailer ────────────────────────────────────────────────────────────────
# Remetente dos transactionals (cadastro de empresa, notificacoes, etc.).
# `no-reply@` deliberado: desencoraja resposta para caixa que ninguem le.
BEHELD_MAIL_FROM=no-reply@beheld.dev

# ─── SMTP (porta 465 = TLS implicito / SMTPS) ──────────────────────────────
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_DOMAIN=beheld.dev
SMTP_USERNAME=hi@beheld.dev
SMTP_PASSWORD=change-me
SMTP_AUTHENTICATION=login
SMTP_TLS=true

# ─── Operacionais ──────────────────────────────────────────────────────────
# Forca HTTPS via HSTS + secure cookies. So setar "false" na janela de
# bootstrap antes do TLS estar provisionado.
BEHELD_FORCE_SSL=true

# debug | info | warn | error | fatal
RAILS_LOG_LEVEL=info
