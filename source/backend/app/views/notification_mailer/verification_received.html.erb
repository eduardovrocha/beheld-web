<!DOCTYPE html>
<html>
<body style="font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; max-width: 560px; margin: 24px auto; color: #0f172a;">
  <p style="font-weight: 600; margin: 0 0 4px;"><%= @company.name %></p>
  <% if @verification.job_title.present? || @verification.area.present? %>
    <p style="color: #64748b; margin: 0 0 4px; font-size: 14px;">
      <%= [@verification.job_title, @verification.area].compact_blank.join(" · ") %>
    </p>
  <% end %>
  <p style="color: #64748b; margin: 0; font-size: 14px;">
    <%= "#{@verification.verified_at.strftime("%d/%m/%Y")} #{t("common.at")} #{@verification.verified_at.strftime("%H:%M")}" %>
  </p>
</body>
</html>
