<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>DevProfile · perfil verificado</title>
  <meta name="description" content="Perfil técnico verificado criptograficamente — DevProfile.">
  <style>
    /* Self-contained CSS — no external requests, no JS required for scores. */
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0f172a;
      color: #e2e8f0;
      line-height: 1.5;
      min-height: 100vh;
    }
    .container { max-width: 760px; margin: 0 auto; padding: 24px 16px 80px; }

    a { color: #38bdf8; text-decoration: none; }
    a:hover { text-decoration: underline; }

    header.site {
      display: flex; align-items: center; justify-content: space-between;
      padding-bottom: 24px; border-bottom: 1px solid #1e293b;
      margin-bottom: 32px;
    }
    header.site .brand { font-weight: 700; letter-spacing: -0.02em; color: #f1f5f9; }
    header.site nav { display: flex; gap: 16px; font-size: 0.875rem; color: #94a3b8; }

    .banner {
      padding: 12px 16px; border-radius: 12px; margin-bottom: 24px;
      font-size: 0.875rem;
    }
    .banner-warn { background: rgba(234, 179, 8, 0.12); color: #fde68a; border: 1px solid rgba(234, 179, 8, 0.3); }

    h1 { font-size: 1.875rem; margin: 0 0 8px; letter-spacing: -0.02em; color: #f1f5f9; }
    h2 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #94a3b8; margin: 0 0 12px; }
    .subtitle { color: #94a3b8; font-size: 0.875rem; margin-bottom: 32px; }

    section.card {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid #1e293b;
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 24px;
    }

    /* ── Score overall — destacado ───────────────────────────────────────── */
    .overall {
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.6));
      border: 1px solid #334155;
    }
    .overall .label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: #94a3b8; }
    .overall .value {
      font-size: 4rem; font-weight: 800; letter-spacing: -0.04em;
      line-height: 1; margin: 8px 0 4px;
    }
    .overall .of { color: #64748b; font-size: 1.125rem; }
    .overall .bar { height: 12px; border-radius: 6px; background: #1e293b; overflow: hidden; margin-top: 16px; }
    .overall .bar > .fill { height: 100%; transition: width 0.4s ease; }

    /* Diferenciador visual entre overall e demais scores. */
    .scores-divider {
      height: 1px; background: #1e293b; margin: 0 0 16px;
    }

    /* ── Score bars (4 dimensões) ────────────────────────────────────────── */
    .score-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 12px;
      padding: 6px 0;
    }
    .score-row .name { color: #cbd5e1; font-size: 0.875rem; }
    .score-row .num { font-family: ui-monospace, SFMono-Regular, monospace; color: #f1f5f9; font-weight: 600; min-width: 2.5rem; text-align: right; }
    .score-row .bar { height: 8px; background: #1e293b; border-radius: 4px; overflow: hidden; }
    .score-row .bar > .fill { height: 100%; transition: width 0.4s ease; }

    /* Cores aplicadas ao .fill via classes utilitárias. */
    .fill-green  { background: #22c55e; }
    .fill-yellow { background: #eab308; }
    .fill-red    { background: #ef4444; }

    /* ── Seções narrativas (L1 / L2) ─────────────────────────────────────── */
    .section-headline {
      font-family: ui-monospace, SFMono-Regular, monospace;
      font-size: 1rem; color: #e2e8f0;
      margin: 0 0 16px;
    }
    .section-headline strong { color: #f1f5f9; }
    .section-headline .meta { color: #64748b; font-size: 0.875rem; margin-left: 8px; }

    dl.facts { margin: 0; display: grid; grid-template-columns: 1fr 2fr; gap: 8px 16px; }
    dl.facts dt { color: #94a3b8; font-size: 0.875rem; }
    dl.facts dd { margin: 0; color: #e2e8f0; font-size: 0.875rem; }

    .empty-note { color: #64748b; font-style: italic; }

    /* ── Verificação ─────────────────────────────────────────────────────── */
    #verification .row { display: flex; align-items: baseline; gap: 8px; padding: 2px 0; font-size: 0.875rem; }
    #verification .row .mark { width: 1.25rem; text-align: center; font-weight: 700; }
    #verification .row.ok  .mark { color: #22c55e; }
    #verification .row.bad .mark { color: #ef4444; }
    #verification .row.warn .mark { color: #eab308; }
    #verification .row.pending .mark { color: #64748b; }

    .pubkey {
      margin-top: 16px;
      display: flex; align-items: center; gap: 8px;
      font-size: 0.8125rem; color: #94a3b8;
    }
    .pubkey code { font-family: ui-monospace, SFMono-Regular, monospace; color: #e2e8f0; }
    .pubkey button {
      background: #1e293b; color: #cbd5e1; border: 1px solid #334155;
      padding: 4px 10px; border-radius: 6px; cursor: pointer; font-size: 0.75rem;
    }
    .pubkey button:hover { background: #334155; }

    footer.foot {
      margin-top: 48px; text-align: center; color: #475569;
      font-size: 0.8125rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="site">
      <div class="brand">DevProfile</div>
      <nav>
        <a href="<%= verify_badge_path(id: @bundle.short_id, format: :svg) %>" target="_blank" rel="noopener">Badge</a>
        <a href="<%= verify_path(id: @bundle.short_id, format: :json) %>">JSON</a>
      </nav>
    </header>
    <%= yield %>
    <footer class="foot">
      Verificação 100% no seu navegador via Web Crypto API · nenhum dado sai daqui.
    </footer>
  </div>
</body>
</html>
