<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>DevProfile · perfil verificado</title>
  <meta name="description" content="Perfil técnico verificado criptograficamente — DevProfile.">

  <%# Pre-paint theme bootstrap — runs before <style> renders so dark-mode
      users never see a flash of light. Reads the persisted preference
      (auto | light | dark) from localStorage. %>
  <script>
    (function() {
      try {
        var saved = localStorage.getItem('dp-theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      } catch (_) {}
    })();
  </script>

  <style>
    /* ── Design tokens — aligned with the SPA palette (slate + emerald) ──── */
    /*
       The Vite SPA at :5173 is dark-only (html bg-slate-950 text-slate-100,
       emerald-400 accent).  Portal mirrors that token set in dark mode and
       derives a complementary light theme using lighter slate steps.
       Tokens are flipped via prefers-color-scheme + data-theme.
    */
    :root {
      /* Light theme — inverted slate stack with emerald accent. */
      --background:         #f8fafc; /* slate-50  */
      --foreground:         #0f172a; /* slate-900 */
      --card:               #ffffff;
      --surface-muted:      #f1f5f9; /* slate-100 */
      --border:             #e2e8f0; /* slate-200 */
      --muted:              #f1f5f9;
      --muted-foreground:   #64748b; /* slate-500 */
      --primary:            #0f172a;
      --primary-foreground: #f8fafc;
      --accent:             #059669; /* emerald-600 */
      --success:            #10b981; /* emerald-500 */
      --warning:            #d97706; /* amber-600   */
      --danger:             #e11d48; /* rose-600    */
      --score-green:        #10b981; /* emerald-500 */
      --score-yellow:       #d97706; /* amber-600   */
      --score-red:          #e11d48; /* rose-600    */
      --radius:             16px;
      --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
      --font-sans: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* Auto dark — when the user has no explicit choice and the OS prefers dark. */
    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --background:         #020617; /* slate-950 — same as SPA html bg */
        --foreground:         #f1f5f9; /* slate-100 — same as SPA text   */
        --card:               #0f172a; /* slate-900 — card surface       */
        --surface-muted:      #1e293b; /* slate-800 — subtle muted       */
        --border:             #1e293b; /* slate-800 — same as SPA border */
        --muted:              #1e293b;
        --muted-foreground:   #94a3b8; /* slate-400 — secondary text     */
        --primary:            #f1f5f9;
        --primary-foreground: #020617;
        --accent:             #34d399; /* emerald-400 — primary accent   */
        --success:            #34d399;
        --warning:            #fbbf24; /* amber-400 */
        --danger:             #fb7185; /* rose-400  */
        --score-green:        #34d399;
        --score-yellow:       #fbbf24;
        --score-red:          #fb7185;
      }
    }

    /* Explicit dark — wins over OS preference. */
    :root[data-theme="dark"] {
      --background:         #020617;
      --foreground:         #f1f5f9;
      --card:               #0f172a;
      --surface-muted:      #1e293b;
      --border:             #1e293b;
      --muted:              #1e293b;
      --muted-foreground:   #94a3b8;
      --primary:            #f1f5f9;
      --primary-foreground: #020617;
      --accent:             #34d399;
      --success:            #34d399;
      --warning:            #fbbf24;
      --danger:             #fb7185;
      --score-green:        #34d399;
      --score-yellow:       #fbbf24;
      --score-red:          #fb7185;
    }

    /* Explicit light — wins even when the OS prefers dark. */
    :root[data-theme="light"] {
      --background:         #f8fafc;
      --foreground:         #0f172a;
      --card:               #ffffff;
      --surface-muted:      #f1f5f9;
      --border:             #e2e8f0;
      --muted:              #f1f5f9;
      --muted-foreground:   #64748b;
      --primary:            #0f172a;
      --primary-foreground: #f8fafc;
      --accent:             #059669;
      --success:            #10b981;
      --warning:            #d97706;
      --danger:             #e11d48;
      --score-green:        #10b981;
      --score-yellow:       #d97706;
      --score-red:          #e11d48;
    }

    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--background);
      color: var(--foreground);
      font-family: var(--font-sans);
      line-height: 1.45;
      min-height: 100vh;
      transition: background-color 0.2s ease, color 0.2s ease;
    }
    a { color: var(--foreground); text-decoration: underline; text-underline-offset: 3px; }
    a:hover { color: var(--muted-foreground); }

    .container { max-width: 880px; margin: 0 auto; padding: 32px 16px 80px; position: relative; }

    .text-mono { font-family: var(--font-mono); }
    .tabular   { font-variant-numeric: tabular-nums; }

    .text-muted   { color: var(--muted-foreground); }
    .text-primary { color: var(--primary); }
    .text-accent  { color: var(--accent); }
    .text-success { color: var(--success); }
    .text-warning { color: var(--warning); }
    .text-score-red    { color: var(--score-red); }
    .text-score-yellow { color: var(--score-yellow); }
    .text-score-green  { color: var(--score-green); }

    /* ── Theme toggle ──────────────────────────────────────────────────────── */
    .topbar {
      display: flex; justify-content: flex-end; align-items: center; gap: 8px;
      margin-bottom: 16px;
    }
    .theme-toggle {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 10px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--card);
      color: var(--muted-foreground);
      font-family: var(--font-mono); font-size: 0.6875rem;
      cursor: pointer;
      transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }
    .theme-toggle:hover { color: var(--foreground); border-color: color-mix(in srgb, var(--foreground) 25%, var(--border)); }
    .theme-toggle .icon { font-size: 0.875rem; line-height: 1; }
    /* Visibility per active theme — JS sets data-mode; we also show the
       fallback (system/auto) label when nothing is forced. */
    .theme-toggle .label-light,
    .theme-toggle .label-dark,
    .theme-toggle .label-auto { display: none; }
    :root[data-theme="light"] .theme-toggle .label-light { display: inline; }
    :root[data-theme="dark"]  .theme-toggle .label-dark  { display: inline; }
    :root:not([data-theme])   .theme-toggle .label-auto  { display: inline; }

    /* ── article shell ─────────────────────────────────────────────────────── */
    article.profile {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }

    /* ── header ────────────────────────────────────────────────────────────── */
    header.profile-head {
      background: color-mix(in srgb, var(--surface-muted) 60%, transparent);
      border-bottom: 1px solid var(--border);
      padding: 32px;
      display: flex; align-items: flex-start; justify-content: space-between; gap: 24px;
    }
    .head-left { display: flex; align-items: center; gap: 24px; }
    .avatar {
      width: 80px; height: 80px;
      display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border);
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--muted-foreground);
    }
    h1.dev-name { font-size: 1.875rem; margin: 0 0 4px; letter-spacing: -0.02em; }
    .dev-id { font-family: var(--font-mono); font-size: 0.875rem; color: var(--muted-foreground); margin: 0; }
    .verify-pill {
      display: inline-flex; align-items: center; gap: 8px;
      margin-top: 12px;
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
      color: var(--success);
    }
    .pulse { position: relative; display: inline-flex; width: 8px; height: 8px; }
    .pulse::before {
      content: ""; position: absolute; inset: 0;
      border-radius: 999px; background: var(--success); opacity: 0.5;
      animation: pulse-ping 1.6s cubic-bezier(0, 0, 0.2, 1) infinite;
    }
    .pulse::after {
      content: ""; position: relative; display: inline-flex; width: 8px; height: 8px;
      border-radius: 999px; background: var(--success);
    }
    @keyframes pulse-ping {
      0%   { transform: scale(1);   opacity: 0.5; }
      75%, 100% { transform: scale(2); opacity: 0; }
    }
    .head-right { text-align: right; }
    .overall-label {
      font-family: var(--font-mono); font-size: 0.625rem; text-transform: uppercase;
      letter-spacing: 0.2em; color: var(--muted-foreground); margin-bottom: 4px;
    }
    .overall-number { font-family: var(--font-mono); font-size: 3.75rem; font-weight: 700; line-height: 1; color: var(--primary); }

    /* ── stats grid (5 cells) ──────────────────────────────────────────────── */
    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      border-bottom: 1px solid var(--border);
    }
    @media (min-width: 720px) { .stats { grid-template-columns: repeat(5, 1fr); } }
    .stat {
      padding: 24px;
      border-bottom: 1px solid var(--border);
    }
    @media (min-width: 720px) {
      .stat { border-bottom: 0; border-right: 1px solid var(--border); }
      .stat:last-child { border-right: 0; }
    }
    .stat-label {
      margin-bottom: 16px;
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-mono); font-size: 0.625rem; text-transform: uppercase;
      color: var(--muted-foreground);
    }
    /* Info hint — reveals stat-tip on hover/focus (CSS-only). */
    .stat-info {
      position: relative;
      display: inline-flex; align-items: center; justify-content: center;
      width: 14px; height: 14px;
      cursor: help;
      color: color-mix(in srgb, var(--muted-foreground) 80%, transparent);
      outline: none;
      transition: color 0.15s ease;
    }
    .stat-info:hover, .stat-info:focus { color: var(--foreground); }
    .stat-tip {
      position: absolute;
      left: 0; bottom: calc(100% + 8px);
      z-index: 20;
      width: 18rem; max-width: 80vw;
      display: none;
      flex-direction: column;
      gap: 8px;
      padding: 16px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 -10px 25px rgba(0, 0, 0, 0.08);
      text-transform: none;
      letter-spacing: normal;
      pointer-events: none;
    }
    .stat-info:hover .stat-tip,
    .stat-info:focus .stat-tip,
    .stat-info:focus-within .stat-tip { display: flex; }
    .stat-tip-head {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-mono);
      font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .stat-tip-desc {
      font-size: 0.6875rem;
      line-height: 1.45;
      color: var(--muted-foreground);
    }

    /* Optional scale legend appended to a tooltip (used by Average Test
       Ratio).  Stacked rows of [coloured pill | range | label]. */
    .tip-scale-title {
      font-family: var(--font-mono);
      font-size: 0.5625rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--muted-foreground);
      margin-top: 4px;
    }
    .tip-scale-row {
      display: flex; align-items: center; gap: 8px;
      font-size: 0.6875rem;
    }
    .tip-scale-bar {
      display: inline-block;
      width: 24px; height: 6px;
      border-radius: 999px;
    }
    .tip-scale-range { font-family: var(--font-mono); color: var(--foreground); }
    .tip-scale-label { text-transform: uppercase; letter-spacing: 0.05em; }
    .tip-scale-row.low      .tip-scale-bar { background: var(--score-red);    }
    .tip-scale-row.low      .tip-scale-label { color: var(--score-red);   }
    .tip-scale-row.average  .tip-scale-bar { background: var(--score-yellow); }
    .tip-scale-row.average  .tip-scale-label { color: var(--score-yellow); }
    .tip-scale-row.good     .tip-scale-bar { background: var(--score-green);  }
    .tip-scale-row.good     .tip-scale-label { color: var(--score-green); }
    .tip-scale-row.excellent .tip-scale-bar { background: var(--accent); }
    .tip-scale-row.excellent .tip-scale-label { color: var(--accent); }
    .stat-value { font-family: var(--font-mono); font-size: 1.25rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .stat-bar { margin-top: 8px; height: 4px; width: 100%; background: var(--muted); border-radius: 999px; overflow: hidden; }
    .stat-bar > .fill { height: 100%; background: var(--primary); transition: width 0.4s ease; }
    .stat-bar > .fill.fill-green  { background: var(--score-green); }
    .stat-bar > .fill.fill-yellow { background: var(--score-yellow); }
    .stat-bar > .fill.fill-red    { background: var(--score-red); }
    .stat-bar > .fill.fill-accent { background: var(--accent); }

    /* ── section base ──────────────────────────────────────────────────────── */
    section.profile-section {
      padding: 32px;
      border-bottom: 1px solid var(--border);
    }
    .section-title {
      display: flex; align-items: center; gap: 8px;
      margin: 0 0 24px;
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.2em;
      color: var(--muted-foreground);
    }
    .section-title .dot { width: 6px; height: 6px; border-radius: 999px; background: var(--primary); }
    .section-title .dot.accent { background: var(--accent); }
    .section-title strong { color: var(--foreground); font-weight: 700; }
    .section-sub { font-size: 0.75rem; color: var(--muted-foreground); margin: 0 0 4px; }

    /* ── trend chart ──────────────────────────────────────────────────────── */
    .trend-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 24px; flex-wrap: wrap; }
    .trend-stats { display: flex; gap: 12px; flex-wrap: wrap; }
    .stat-card {
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--surface-muted) 60%, transparent);
      border-radius: 6px;
      padding: 8px 12px;
    }
    .stat-card .k { font-family: var(--font-mono); font-size: 0.5625rem; text-transform: uppercase; color: var(--muted-foreground); }
    .stat-card .v { font-family: var(--font-mono); font-size: 0.875rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .stat-card.delta-positive .v { color: var(--accent); }
    .stat-card.delta-negative .v { color: var(--danger); }

    .chart-wrap { height: 256px; width: 100%; }
    .chart-wrap svg { width: 100%; height: 100%; max-height: 256px; display: block; }
    .chart-empty {
      height: 256px; display: flex; align-items: center; justify-content: center;
      border: 1px dashed var(--border); border-radius: 8px;
      color: var(--muted-foreground); font-size: 0.875rem;
    }

    .chart-legend { margin-top: 16px; display: flex; flex-wrap: wrap; gap: 8px 20px; }
    .chart-legend .item { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 0.6875rem; color: var(--muted-foreground); }
    .chart-legend .swatch { width: 16px; border-radius: 1px; display: inline-block; }

    /* ── L1 / L2 columns ──────────────────────────────────────────────────── */
    .two-col { display: grid; gap: 48px; padding: 32px; }
    @media (min-width: 720px) { .two-col { grid-template-columns: 1fr 1fr; } }

    .fact-row { display: flex; align-items: flex-end; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
    .fact-row + .fact-row { margin-top: 12px; }
    .fact-label {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--muted-foreground); font-size: 0.875rem;
    }
    .fact-value { font-family: var(--font-mono); font-weight: 700; }
    .fact-value.small { font-size: 0.875rem; }
    .fact-value-suffix {
      margin-left: 6px;
      font-weight: 400;
      font-size: 0.6875rem;
      color: var(--muted-foreground);
    }

    .chip-block { margin-top: 16px; }
    .chip-label { font-family: var(--font-mono); font-size: 0.625rem; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 8px; }
    .chip-row { display: flex; flex-wrap: wrap; gap: 8px; }
    .chip {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      border: 1px solid color-mix(in srgb, var(--primary) 15%, var(--border));
      background: color-mix(in srgb, var(--primary) 5%, transparent);
      font-family: var(--font-mono); font-size: 0.75rem;
      color: var(--foreground);
    }
    .chip-muted {
      border: 1px solid var(--border);
      background: transparent;
      padding: 2px 8px;
      font-size: 0.6875rem; color: var(--muted-foreground);
      border-radius: 4px;
      font-family: var(--font-mono);
      display: inline-block;
    }

    .empty-card {
      border: 1px dashed var(--border);
      border-radius: 8px;
      padding: 32px;
      text-align: center;
    }
    .empty-card .badge {
      margin-bottom: 8px;
      font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase;
      color: var(--muted-foreground);
    }
    .empty-card p { color: var(--muted-foreground); font-size: 0.875rem; margin: 0; }

    /* ── proof footer ──────────────────────────────────────────────────────── */
    /* Shares the card surface palette — same family as the header / L1 / L2
       panels, just a separator and a touch of surface-muted to mark the
       section break. */
    .proof {
      background: color-mix(in srgb, var(--surface-muted) 60%, transparent);
      color: var(--foreground);
      border-top: 1px solid var(--border);
      padding: 24px;
      font-family: var(--font-mono);
    }
    .proof-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .proof-head .lbl { font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--muted-foreground); }
    .proof-head .ok  { font-size: 0.625rem; font-weight: 700; color: var(--accent); }
    .proof-head .ok.bad { color: var(--danger); }
    .proof-row { display: flex; gap: 16px; font-size: 0.6875rem; line-height: 1.5; }
    .proof-row + .proof-row { margin-top: 8px; }
    .proof-row .field { width: 64px; flex-shrink: 0; color: var(--muted-foreground); }
    .proof-row .val { word-break: break-all; color: var(--foreground); opacity: 0.85; }

    /* SHA256 / ED25519 / PUB_KEY chips — hover (or focus) opens a tooltip
       card with the field value and a short description.  Pure CSS so it
       works without JavaScript. */
    .proof-chips {
      display: flex; flex-wrap: wrap;
      gap: 12px 32px;
      margin-bottom: 16px;
    }
    .proof-chip {
      position: relative;
      display: inline-flex; align-items: center;
      cursor: help;
      outline: none;
    }
    .proof-chip-label {
      font-family: var(--font-mono);
      font-size: 0.625rem; font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted-foreground);
      text-decoration: underline dotted;
      text-underline-offset: 4px;
      transition: color 0.15s ease;
    }
    .proof-chip:hover .proof-chip-label,
    .proof-chip:focus .proof-chip-label { color: var(--foreground); }

    /* Tooltip card — opens UPWARD (above the chip).  Same shape as the
       reference mock (icon + accent label, value, muted description). */
    .proof-tip {
      position: absolute;
      left: 0; bottom: calc(100% + 8px);
      z-index: 20;
      width: 20rem; max-width: 90vw;
      display: none;
      flex-direction: column;
      gap: 8px;
      padding: 16px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 -10px 25px rgba(0, 0, 0, 0.08);
      pointer-events: none;
    }
    .proof-chip:hover .proof-tip,
    .proof-chip:focus .proof-tip,
    .proof-chip:focus-within .proof-tip { display: flex; }

    .proof-tip-head {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-mono);
      font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .proof-tip-value {
      font-family: var(--font-mono);
      font-size: 0.75rem; font-weight: 600;
      word-break: break-all;
      color: var(--foreground);
      line-height: 1.5;
    }
    .proof-tip-desc {
      font-size: 0.6875rem;
      line-height: 1.4;
      color: var(--muted-foreground);
    }

    /* ── banners ───────────────────────────────────────────────────────────── */
    .banner {
      padding: 12px 16px; border-radius: 12px; margin-bottom: 24px;
      font-size: 0.875rem;
    }
    .banner-warn {
      background: color-mix(in srgb, var(--warning) 12%, transparent);
      color: color-mix(in srgb, var(--warning) 85%, var(--foreground));
      border: 1px solid color-mix(in srgb, var(--warning) 35%, transparent);
    }

    /* ── helpers ───────────────────────────────────────────────────────────── */
    .meta-strip { color: var(--muted-foreground); font-size: 0.875rem; margin-top: 16px; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="topbar">
      <button type="button" class="theme-toggle" id="theme-toggle" aria-label="Alternar tema" title="Alternar tema (auto / claro / escuro)">
        <span class="icon" aria-hidden="true">☀︎</span>
        <span class="label-auto">auto</span>
        <span class="label-light">claro</span>
        <span class="label-dark">escuro</span>
      </button>
    </div>
    <%= yield %>
    <p class="meta-strip">
      Verificação 100% no seu navegador via Web Crypto API · nenhum dado sai daqui.
    </p>
  </div>

  <script>
    (function() {
      const btn = document.getElementById('theme-toggle');
      if (!btn) return;
      const root = document.documentElement;
      const icon = btn.querySelector('.icon');

      function applyIcon() {
        const t = root.getAttribute('data-theme');
        // auto → ☀︎/☾ based on system; explicit → matching glyph
        if (t === 'dark') { icon.textContent = '☾'; return; }
        if (t === 'light') { icon.textContent = '☀︎'; return; }
        // auto: reflect what the system would render right now
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        icon.textContent = prefersDark ? '☾' : '☀︎';
      }

      function cycle() {
        const current = root.getAttribute('data-theme'); // null | "light" | "dark"
        let next;
        if (current === null)        next = 'light';
        else if (current === 'light') next = 'dark';
        else                          next = null; // back to auto

        if (next === null) {
          root.removeAttribute('data-theme');
          try { localStorage.removeItem('dp-theme'); } catch (_) {}
        } else {
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('dp-theme', next); } catch (_) {}
        }
        applyIcon();
      }

      btn.addEventListener('click', cycle);

      // Live-update the icon when the OS theme changes in auto mode.
      if (window.matchMedia) {
        const mq = window.matchMedia('(prefers-color-scheme: dark)');
        if (mq.addEventListener) mq.addEventListener('change', applyIcon);
      }
      applyIcon();
    })();
  </script>
</body>
</html>
