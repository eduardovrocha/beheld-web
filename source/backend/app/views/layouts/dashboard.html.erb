<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>beheld · dashboard</title>
  <%= csrf_meta_tags %>
  <style>
    :root {
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #64748b;
      --border: #e2e8f0;
      --accent: #059669;
      --warn: #d97706;
      --danger: #dc2626;
      --neutral: #94a3b8;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f172a; --card: #1e293b; --text: #f1f5f9;
        --muted: #94a3b8; --border: #334155;
      }
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); }
    main { max-width: 880px; margin: 0 auto; padding: 32px 20px 96px; }
    header.top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 24px; }
    header.top h1 { margin: 0; font-size: 20px; }
    header.top .meta { color: var(--muted); font-size: 13px; }
    section.card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; margin-bottom: 20px; }
    section.card > h2 { margin: 0 0 16px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); font-weight: 600; }
    .empty { color: var(--muted); font-size: 14px; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; vertical-align: middle; }
    .badge.verified { background: color-mix(in srgb, var(--accent) 15%, transparent); color: var(--accent); }
    .badge.outdated { background: color-mix(in srgb, var(--warn)   15%, transparent); color: var(--warn); }
    .badge.revoked  { background: color-mix(in srgb, var(--neutral) 25%, transparent); color: var(--muted); }
    .row { display: flex; justify-content: space-between; gap: 12px; padding: 12px 0; border-top: 1px solid var(--border); }
    .row:first-of-type { border-top: 0; }
    .row .info { flex: 1; min-width: 0; }
    .row .info .title { font-weight: 600; }
    .row .info .sub { color: var(--muted); font-size: 13px; margin-top: 2px; }
    .row .actions { display: flex; gap: 8px; align-items: center; }
    a.url { color: var(--accent); text-decoration: none; word-break: break-all; }
    a.url:hover { text-decoration: underline; }
    form.inline { display: inline; margin: 0; }
    button, .button { font: inherit; padding: 6px 12px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text); cursor: pointer; }
    button.primary { background: var(--accent); color: white; border-color: var(--accent); }
    button.danger  { color: var(--danger); border-color: color-mix(in srgb, var(--danger) 40%, var(--border)); }
    button[disabled] { opacity: 0.5; cursor: not-allowed; }
    .flash { padding: 10px 14px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
    .flash.notice { background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); }
    .flash.alert  { background: color-mix(in srgb, var(--warn)   12%, transparent); color: var(--warn); }
    .warning { padding: 12px 16px; background: color-mix(in srgb, var(--warn) 12%, transparent); border: 1px solid var(--warn); border-radius: 8px; margin-bottom: 20px; font-size: 14px; color: var(--warn); }
    .warning a { color: inherit; font-weight: 600; }
    form.settings { display: grid; gap: 12px; }
    form.settings label { display: grid; gap: 4px; font-size: 13px; color: var(--muted); }
    form.settings input[type="text"], form.settings input[type="email"], form.settings input[type="tel"], form.settings input[type="url"] {
      padding: 8px 10px; font: inherit; color: var(--text); background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    }
    form.settings .checkbox { flex-direction: row; gap: 8px; align-items: center; }
    form.settings .checkbox input { transform: translateY(1px); }
    .body-preview { color: var(--muted); font-size: 13px; margin-top: 4px; white-space: pre-wrap; word-break: break-word; }
  </style>
</head>
<body>
  <main>
    <header class="top">
      <h1>beheld · dashboard</h1>
      <span class="meta">Conta <code><%= current_account.fingerprint.first(12) %>…</code></span>
    </header>

    <% if flash[:notice].present? %><div class="flash notice"><%= flash[:notice] %></div><% end %>
    <% if flash[:alert].present?  %><div class="flash alert"><%=  flash[:alert]  %></div><% end %>

    <%= yield %>
  </main>
</body>
</html>
