<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>beheld</title>
  <%= csrf_meta_tags %>
  <style>
    :root {
      --bg: #f8fafc; --card: #ffffff; --text: #0f172a;
      --muted: #64748b; --border: #e2e8f0;
      --accent: #059669; --warn: #d97706; --danger: #dc2626;
    }
    @media (prefers-color-scheme: dark) {
      :root { --bg: #0f172a; --card: #1e293b; --text: #f1f5f9; --muted: #94a3b8; --border: #334155; }
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); }
    main { max-width: 480px; margin: 0 auto; padding: 64px 20px; }
    header.top { margin-bottom: 24px; }
    header.top h1 { margin: 0; font-size: 18px; letter-spacing: 0.04em; }
    section.card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 24px 28px; }
    section.card h2 { margin: 0 0 16px; font-size: 16px; font-weight: 600; }
    .empty { color: var(--muted); font-size: 14px; }
    .flash { padding: 10px 14px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
    .flash.notice { background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); }
    .flash.alert  { background: color-mix(in srgb, var(--warn)   12%, transparent); color: var(--warn); }
    button, .button { font: inherit; padding: 8px 14px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text); cursor: pointer; text-decoration: none; display: inline-block; }
    button.primary { background: var(--accent); color: white; border-color: var(--accent); }
    form.settings { display: grid; gap: 12px; }
    form.settings label { display: grid; gap: 4px; font-size: 13px; color: var(--muted); }
    form.settings input { padding: 8px 10px; font: inherit; color: var(--text); background: var(--bg); border: 1px solid var(--border); border-radius: 6px; }
    a { color: var(--accent); }
  </style>
</head>
<body>
  <main>
    <header class="top"><h1>beheld</h1></header>
    <% if flash[:notice].present? %><div class="flash notice"><%= flash[:notice] %></div><% end %>
    <% if flash[:alert].present?  %><div class="flash alert"><%=  flash[:alert]  %></div><% end %>
    <%= yield %>
  </main>
</body>
</html>
