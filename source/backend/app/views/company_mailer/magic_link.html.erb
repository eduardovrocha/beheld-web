<!DOCTYPE html>
<html>
<body style="font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; max-width: 560px; margin: 24px auto; color: #0f172a;">
  <p><%= t("mailers.company.magic_link.greeting") %><%= ", #{@company.name}" if @company.name.present? %>,</p>
  <p><%= t("mailers.company.magic_link.intro") %></p>
  <p>
    <a href="<%= @verify_url %>" style="display: inline-block; padding: 10px 16px; background: #059669; color: #fff; text-decoration: none; border-radius: 6px;">
      <%= t("mailers.company.magic_link.cta") %>
    </a>
  </p>
  <p style="color: #64748b; font-size: 13px;">
    <%= t("mailers.company.magic_link.copy_paste") %><br>
    <code><%= @verify_url %></code>
  </p>
  <p style="color: #64748b; font-size: 13px;"><%= t("mailers.company.magic_link.validity") %></p>
</body>
</html>
