# Exemplo de variaveis Vite usadas pelo frontend.
# Vite carrega automaticamente `.env`, `.env.development`, `.env.production`
# e seus `.local` overrides. Apenas variaveis com prefixo VITE_ ficam
# expostas no bundle do browser.

# URL do backend Rails — onde o SPA faz fetch via browser.
# Dev:  http://localhost:3000
# Prod: /api  (same-origin, atrás do Caddy)
VITE_API_URL=http://localhost:3000

# Target do dev proxy do Vite (vite.config.ts → server.proxy['/api']).
# Dentro do container Docker: http://beheld-backend-dev:3000
# Fora do container:           http://localhost:3000
VITE_API_TARGET=http://beheld-backend-dev:3000
