# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Local agent / token-tracker artifacts (not project state)
.claude/

# Environment overrides (subdirs may also gitignore their own .env files)
.env
.env.local
.env.*.local

# Node / Vite (frontend builds)
node_modules/
**/node_modules/
**/dist/
*.tsbuildinfo

# Ruby / Rails (backend caches and locally generated state)
**/log/*.log
**/tmp/cache/
**/tmp/pids/
**/tmp/sockets/
**/storage/*.sqlite*
**/coverage/

# Docker
docker-compose.override.yml
source/dashboard/

# Per-developer platform key material (key_id ending in -dev). Each dev
# generates their own via scripts/generate-dev-platform-key.sh — the .pub
# and .info.json stay local, the .priv is pasted into .env. The committed
# prod key remains the only source of truth shipped to release builds.
source/backend/keys/platform/*-dev.pub
source/backend/keys/platform/*-dev.info.json

# Design handoff snapshots / landing integration references (generated artifacts)
design_handoff_*/
landing-v2-integration/
landing-v2-integration-nav/

# npm lockfile (frontend uses bun / bun.lock, not npm)
source/frontend/package-lock.json

# Analysis artifacts (graphify, playwright results)
source/graphify-out/
source/dashboard/playwright-results/
test-results/

# Local dev artifacts (not project state)
# handoff.zip — handoff archive, não é código
/handoff.zip
# scripts/dev-login.sh — helper local: emite DevSession de 24h p/ o dashboard
/scripts/dev-login.sh
