# Copy to `.env` (gitignored) and adjust for your host setup.

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_PORT=3000

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
# Base URL the SPA hits at runtime (browser → host). If you change BACKEND_PORT,
# update this here too.
VITE_API_URL=http://localhost:3000

# ── Postgres on the host ────────────────────────────────────────────────────
# DB_HOST defaults to host.docker.internal which resolves to the host on
# Docker Desktop and on Linux via the host-gateway alias.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=beheld_backend_development
DB_NAME_TEST=beheld_backend_test

# ── Redis on the host ───────────────────────────────────────────────────────
REDIS_URL=redis://host.docker.internal:6379/1

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use "*" only in development.
CORS_ORIGINS=*

# ── GitHub OAuth (Phase 5 / F5.6 — identity attestation) ────────────────────
# Two OAuth Apps exist, one per environment:
#   prod  → DevProfile Attestation         (Client ID: Ov23ligjSeBo4NfXzr7j)
#   dev   → DevProfile Attestation (dev)   (Client ID: Ov23liVeZQqKw2fLYsP8)
#
# Local dev uses the (dev) app — callback http://localhost:3000/api/auth/github/callback.
# Production uses the prod app — callback https://beheld.dev/api/auth/github/callback.
#
# The client_id is public; the client_secret lives only in the founder's
# password manager and is pasted into this file (gitignored). For production,
# both are set as env vars on the host. See documents/platform-key-ops.md for
# the broader credentials policy.
GITHUB_OAUTH_CLIENT_ID=Ov23liVeZQqKw2fLYsP8
GITHUB_OAUTH_CLIENT_SECRET=

# ── Platform signing key (Phase 5 / F5.6.1 — attestation issuance) ──────────
# The private key NEVER lives in this repo. Generate via the procedure in
# documents/platform-key-ops.md and paste the .priv.b64 content below.
# Production hosts use the same env var names, populated via host env files.
BEHELD_PLATFORM_KEY_ID=beheld-platform-2026-q2
BEHELD_PLATFORM_PRIVATE_KEY=
