# Copy to `.env` (gitignored) and adjust for your host setup.

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_PORT=3000

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
# Base URL the SPA hits at runtime (browser → host). If you change BACKEND_PORT,
# update this here too.
VITE_API_URL=http://localhost:3000

# ── Postgres on the host ────────────────────────────────────────────────────
# DB_HOST defaults to host.docker.internal which resolves to the host on
# Docker Desktop and on Linux via the host-gateway alias.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=beheld_backend_development
DB_NAME_TEST=beheld_backend_test

# ── Redis on the host ───────────────────────────────────────────────────────
REDIS_URL=redis://host.docker.internal:6379/1

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use "*" only in development.
CORS_ORIGINS=*

# ── Portal público (obrigatória) ────────────────────────────────────────────
# URL pública usada em links de email, dashboard e respostas da API. Sem
# fallback — o Rails levanta KeyError se não estiver setada, garantindo que
# um setup mal configurado em dev nunca aponte para produção. Em dev
# normalmente bate o SPA Vite (5173); se o Rails servir as views direto,
# usar 3000.
PORTAL_PUBLIC_URL=http://localhost:5173

# ── Email (Mailtrap Sandbox) ────────────────────────────────────────────────
# Em dev, todos os emails são capturados pelo inbox do Mailtrap em vez de
# saírem para o mundo. Pegar credenciais em:
#   mailtrap.io → Email Testing → My Inbox → Show Credentials → "Ruby on Rails"
# Sem essas vars setadas, ActionMailer levanta na primeira tentativa de
# envio (preferível a "deliver silenciosamente para o vazio" do default
# Rails dev).
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=

# Remetente padrão. Em dev usar @beheld.test pra deixar claro no Mailtrap
# que veio do sandbox; em prod sobrescrever com noreply@beheld.dev.
MAIL_FROM=beheld <noreply@beheld.test>

# ── GitHub OAuth (Phase 5 / F5.6 — identity attestation) ────────────────────
# Two OAuth Apps exist, one per environment:
#   prod  → DevProfile Attestation         (Client ID: Ov23ligjSeBo4NfXzr7j)
#   dev   → DevProfile Attestation (dev)   (Client ID: Ov23liVeZQqKw2fLYsP8)
#
# Local dev uses the (dev) app — callback http://localhost:3000/api/auth/github/callback.
# Production uses the prod app — callback https://beheld.dev/api/auth/github/callback.
#
# The client_id is public; the client_secret lives only in the founder's
# password manager and is pasted into this file (gitignored). For production,
# both are set as env vars on the host. See documents/platform-key-ops.md for
# the broader credentials policy.
GITHUB_OAUTH_CLIENT_ID=Ov23liVeZQqKw2fLYsP8
GITHUB_OAUTH_CLIENT_SECRET=

# ── Platform signing key (Phase 5 / F5.6.1 — attestation issuance) ──────────
# Local dev uses a SEPARATE keypair from production, with key_id suffix
# `-dev`. The .pub + .info.json land at
#   web/source/backend/keys/platform/beheld-platform-2026-q2-dev.{pub,info.json}
# (both gitignored), and the .priv is pasted into this file below.
#
# Generate via:
#   bash deploy/development/generate-dev-platform-key.sh
#
# That script populates both fields below and creates the .pub/.info.json.
# Keeping dev material separate means a released CLI binary (which embeds
# only the prod pub) cannot verify dev-signed attestations — which is
# exactly the property we want.
BEHELD_PLATFORM_KEY_ID=beheld-platform-2026-q2-dev
BEHELD_PLATFORM_PRIVATE_KEY=
