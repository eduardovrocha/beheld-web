# Production env vars for the Rails backend + frontend build.
#
# This file is the EXAMPLE — copy to /etc/devprofile/app.env on the VPS
# (perms 600, root-owned) and fill in the secret values. The real
# /etc/devprofile/app.env is NEVER committed.
#
# Postgres credentials live in a SEPARATE file: /etc/devprofile/postgres.env
# (already generated during VPS bootstrap; no need to edit).

# ── Rails ────────────────────────────────────────────────────────────────────
# Generated with: bundle exec rails secret  (run once locally, paste here)
SECRET_KEY_BASE=

# ── Platform signing key (Phase 5 / F5.6.1) ─────────────────────────────────
# The key_id is public (matches keys/platform/<key_id>.{pub,info.json}).
# The private key is the base64-encoded raw 32-byte Ed25519 seed.
# It lives ONLY in the founder's password manager + here on the VPS.
DEVPROFILE_PLATFORM_KEY_ID=devprofile-platform-2026-q2
DEVPROFILE_PLATFORM_PRIVATE_KEY=

# ── GitHub OAuth (production app) ───────────────────────────────────────────
# Production OAuth App on github.com/settings/developers:
#   "DevProfile Attestation"   Client ID: Ov23ligjSeBo4NfXzr7j
#   callback: https://beheld.dev/api/auth/github/callback
# Secret lives in the founder's password manager — paste below.
GITHUB_OAUTH_CLIENT_ID=Ov23ligjSeBo4NfXzr7j
GITHUB_OAUTH_CLIENT_SECRET=

# ── CORS ────────────────────────────────────────────────────────────────────
# Same-origin in prod, so this list is empty (the SPA is served from the
# same host as the API). If you ever expose the API to third-party origins,
# add them here (comma-separated).
CORS_ORIGINS=
