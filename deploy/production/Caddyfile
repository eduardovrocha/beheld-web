# Production Caddyfile for beheld.
#
# Requires DNS A records for `beheld.dev` AND `install.beheld.dev` to
# resolve to this VPS before deploy — otherwise Let's Encrypt cert
# provisioning will fail on startup. Check with:
#   dig +short beheld.dev install.beheld.dev
#
# Caddy auto-provisions TLS certs via Let's Encrypt on first hit to
# port 443. No manual cert work required.

beheld.dev {
  encode gzip zstd

  log {
    output stdout
    format console
    level INFO
  }

  # ── Rails: API + health + bundle upload ───────────────────────────────────
  handle /api/* {
    reverse_proxy 127.0.0.1:3000
  }
  handle /up {
    reverse_proxy 127.0.0.1:3000
  }
  handle /bundles {
    reverse_proxy 127.0.0.1:3000
  }

  # ── Rails: bundle metadata + badge (path-specific) ────────────────────────
  @rails_bundle_meta path_regexp ^/v/[A-Za-z0-9_\-]+/(summary|badge\.svg)$
  handle @rails_bundle_meta {
    reverse_proxy 127.0.0.1:3000
  }

  # ── Rails: bundle JSON — stable machine-readable suffix ───────────────────
  # `/v/:id.json` is the explicit JSON path (no content negotiation needed).
  # Recommended path for external verifiers + cosign / rekor-cli pipelines.
  # Rewrites the request to `/v/:id` (stripping the `.json` suffix) before
  # proxying so Rails serves it via the same ProfilesController#show path
  # used by the content-negotiated route below. Header_up forces JSON.
  @rails_bundle_json_explicit path_regexp jsonext ^/v/([A-Za-z0-9_\-]+)\.json$
  handle @rails_bundle_json_explicit {
    rewrite * /v/{re.jsonext.1}
    reverse_proxy 127.0.0.1:3000 {
      header_up Accept application/json
    }
  }

  # ── Rails: bundle JSON fetch — content-negotiated ─────────────────────────
  # The SPA's VerifyPublic component fetches `/v/:id` with
  # `Accept: application/json`. Browser direct-nav (Accept: text/html)
  # falls through to the SPA handler below for client-side rendering.
  # The optional trailing slash in the regex tolerates `/v/:id/` so a
  # canonical URL with or without slash routes identically (P0 fix from
  # post-launch verification report).
  @rails_bundle_json {
    path_regexp ^/v/[A-Za-z0-9_\-]+/?$
    header_regexp Accept application/json
  }
  handle @rails_bundle_json {
    reverse_proxy 127.0.0.1:3000
  }

  # ── Install script — same redirect as install.beheld.dev ─────────────────
  # `curl -fsSL beheld.dev/install.sh | sh` follows the 302 and pulls the
  # current scripts/install.sh from `main`. Mirrors install.beheld.dev so
  # both URLs work; the landing's InstallLine ships the
  # beheld.dev/install.sh form, which is the more intuitive one.
  # Target is parameterizable via `BEHELD_INSTALL_SCRIPT_URL` (set in
  # /etc/beheld/app.env). If unset, points at the public GitHub raw URL
  # of the canonical fork — pin to a tag (e.g. `/v0.4.0/`) for immutable
  # installs.
  handle /install.sh {
    redir {$BEHELD_INSTALL_SCRIPT_URL:https://raw.githubusercontent.com/eduardovrocha/beheld/main/scripts/install.sh} 302
  }

  # ── Static SPA (default fallback for everything else) ─────────────────────
  handle {
    root * /srv/frontend
    try_files {path} /index.html
    file_server
  }
}

# ── Install script — redirects to GitHub raw on every request ───────────────
# `curl -fsSL install.beheld.dev | sh` follows the 302 and pulls the latest
# scripts/install.sh from `main`. Same parameterization as `/install.sh`
# acima — set BEHELD_INSTALL_SCRIPT_URL in /etc/beheld/app.env para apontar
# a um fork ou a uma tag fixa.
install.beheld.dev {
  redir {$BEHELD_INSTALL_SCRIPT_URL:https://raw.githubusercontent.com/eduardovrocha/beheld/main/scripts/install.sh} 302
}
